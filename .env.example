PROXY_API_KEY=local-dev-key
HOST=127.0.0.1
PORT=8000
MODEL_PROXY_BACKEND=claude_code
MODEL_PROXY_ENABLED_PROVIDERS=
MODEL_PROXY_PROVIDER_ID=claude_code_cli_proxy
MODEL_PROXY_DISPLAY_NAME=Model Proxy
MODEL_PROXY_STABLE_MODEL=claude
MODEL_PROXY_DEFAULT_MODEL=opus
MODEL_PROXY_ACTIVE_MODEL_FILE=~/.codex/model-proxy-active-model

CLAUDE_MODELS=fable,opus,sonnet,haiku,claude-fable-5,claude-opus-4-8,claude-sonnet-5,claude-haiku-4-5,claude-haiku-4-5-20251001
CLAUDE_COMMAND=claude
CLAUDE_TIMEOUT_SECONDS=300
CLAUDE_SAFE_MODE=1
CLAUDE_PERMISSION_MODE=dontAsk
CLAUDE_DEFAULT_MODEL=opus

OPENAI_MODELS=gpt-5.5,gpt-5.4-mini,gpt-5.3-codex-spark
OPENAI_API_KEY=
MODEL_PROXY_OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=300

GEMINI_MODELS=gemini-3-pro,gemini-2.5-pro,gemini-2.5-flash
GEMINI_COMMAND=gemini
GEMINI_TIMEOUT_SECONDS=300
GEMINI_APPROVAL_MODE=default
GEMINI_EXTENSIONS=none

ANTIGRAVITY_MODELS=gemini-3-pro,gemini-3-flash,gemini-3-1-pro
ANTIGRAVITY_COMMAND=antigravity
ANTIGRAVITY_TIMEOUT_SECONDS=300
ANTIGRAVITY_ARGS_TEMPLATE="--model {model} --output-format json --prompt {prompt}"

GROK_MODELS=grok-4.5
GROK_COMMAND=grok
GROK_TIMEOUT_SECONDS=300
GROK_ARGS_TEMPLATE="--single {prompt} --model {model} --output-format json --max-turns 1 --disable-web-search --no-subagents --permission-mode default --no-memory --verbatim"

CURSOR_MODELS=auto,composer-2.5,grok-4.5,claude-opus-4-8,claude-sonnet-5,gpt-5.5,gemini-3-1-pro
CURSOR_COMMAND=cursor-agent
CURSOR_TIMEOUT_SECONDS=300
CURSOR_ARGS_TEMPLATE="--print --output-format json --model {model} {prompt}"

RESPONSE_TTL_SECONDS=3600
MODEL_PROXY_BASE_URL=http://127.0.0.1:8000
MODEL_PROXY_API_KEY=local-dev-key
MODEL_PROXY_CWD=/Users/michaelboeding/Documents/GitHub/codex-model-proxy
MODEL_PROXY_AUTOSTART=1
MODEL_PROXY_LOG_FILE=~/.codex/model-proxy-control.log
MODEL_PROXY_PID_FILE=~/.codex/model-proxy.pid
